{
  "expo": {
    "name": "Aarti Sangrah",
    "slug": "aarti-sangrah",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "aartisangrah",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.thinkercart.aartisangrah",
      "infoPlist": {
        "CFBundleDisplayName": "Aarti Sangrah",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#faf0dc",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.thinkercart.aartisangrah",
      "versionCode": 1,
      "permissions": ["android.permission.INTERNET"]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#faf9f6",
          "dark": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 200,
            "resizeMode": "contain",
            "backgroundColor": "#131313"
          }
        }
      ],
      "expo-sqlite",
      "expo-localization",
      "expo-updates"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "d84ae34c-6cbe-45ea-92cb-dc4d5b543d71"
      },
      "router": {}
    },
    "updates": {
      "url": "https://u.expo.dev/d84ae34c-6cbe-45ea-92cb-dc4d5b543d71"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "owner": "thinkercart"
  }
}
